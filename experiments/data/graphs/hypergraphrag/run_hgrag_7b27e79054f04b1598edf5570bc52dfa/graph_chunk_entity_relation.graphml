<node id="&quot;LAPSE DATE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"DATE"</data>
  <data key="d4">"Lapse Date is the specific date on which the policy terminates due to non-payment of the premium."&lt;SEP&gt;"The date from which premiums were not paid, leading to a lapse in coverage."&lt;SEP&gt;"The reinstatement application must be made within 2 years of the lapse date."&lt;SEP&gt;"The specific date on which the policy terminates due to non-payment."</data>
