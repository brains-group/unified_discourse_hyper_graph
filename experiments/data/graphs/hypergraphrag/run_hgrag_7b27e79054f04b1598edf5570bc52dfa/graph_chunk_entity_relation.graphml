  <data key="d0">entity</data>
  <data key="d3">"CONTACT INFORMATION"</data>
  <data key="d4">"A phone number to contact TD Insurance."&lt;SEP&gt;"A phone number to contact a TD Insurance representative."&lt;SEP&gt;"A toll-free number to contact TD Insurance representatives for further assistance."&lt;SEP&gt;"A toll-free phone number for canceling the policy."&lt;SEP&gt;"A toll-free phone number for customer service provided by TD Insurance."&lt;SEP&gt;"A toll-free phone number to contact a TD Insurance representative for assistance."&lt;SEP&gt;"A toll-free phone number to contact for corrections or inquiries regarding the policy."&lt;SEP&gt;"The toll-free phone number to contact TD Insurance for cancellation."&lt;SEP&gt;"This is the phone number for contacting an insurance representative regarding Health products."&lt;SEP&gt;"This is the toll-free number to contact TD Insurance."&lt;SEP&gt;"You can contact TD at 1-888-788-0839 to opt out or change communication preferences."</data>
