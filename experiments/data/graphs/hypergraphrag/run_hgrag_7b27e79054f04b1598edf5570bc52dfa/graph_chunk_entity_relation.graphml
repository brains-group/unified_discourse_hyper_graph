  <data key="d3">"POLICY FEATURE"</data>
  <data key="d4">"A feature allowing the policyholder to convert term life insurance to permanent life insurance without medical questions."&lt;SEP&gt;"A provision allowing the insured to convert their current policy to another type, but if exercised during total disability, no premium waivers apply to the new policy."&lt;SEP&gt;"The right to convert temporary insurance to permanent life insurance, available up to the policy anniversary nearest the insured person's 69th birthday."</data>
  <data key="d2">chunk-8236a16ecbc3d46f2cffaf18c4b6343f&lt;SEP&gt;chunk-6e3c19fad0ec74d4024195693875376d&lt;SEP&gt;chunk-9664b19d2f37c02c2b9b34d8418fd48b</data>
