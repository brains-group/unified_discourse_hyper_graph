  <data key="d2">chunk-15042c9c78a8efe744537c5c84db0f52</data>
</node>
<node id="&quot;POLICY SCHEDULE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"DOCUMENT"</data>
  <data key="d4">"A document that displays key details of the insurance policy, including premium payment terms."&lt;SEP&gt;"A document that lists key details of the policy, including the Effective Date."&lt;SEP&gt;"A document that outlines the effective date of coverage."&lt;SEP&gt;"A section of the insurance policy that lists the premiums for the waiver of premiums benefit."&lt;SEP&gt;"The policy schedule contains key details of the insurance policy, including dates, amounts, and personal information."</data>
  <data key="d2">chunk-15042c9c78a8efe744537c5c84db0f52&lt;SEP&gt;chunk-e336bc3335eae1b8a9a02061f363f289&lt;SEP&gt;chunk-6e3c19fad0ec74d4024195693875376d&lt;SEP&gt;chunk-32b292e542e11e187b7d8150c2a86ba7</data>
</node>
