  <data key="d0">entity</data>
  <data key="d3">"PAYMENT METHOD"</data>
  <data key="d4">"The policyholder must notify the insurer to change the payment frequency."</data>
  <data key="d2">chunk-cb04334968af2cf23772b1234fa1ff3c</data>
</node>
<node id="&quot;DISABILITY&quot;">
  <data key="d0">entity</data>
