  <data key="d0">entity</data>
  <data key="d3">"POLICY"</data>
  <data key="d4">"A life insurance policy with a 20-year term, offered by TD Insurance, providing coverage for a fixed period."</data>
  <data key="d2">chunk-3987d1322918db88e8961dd954bc3f19</data>
</node>
<node id="&quot;ENDORSEMENTS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"DOCUMENT"</data>
