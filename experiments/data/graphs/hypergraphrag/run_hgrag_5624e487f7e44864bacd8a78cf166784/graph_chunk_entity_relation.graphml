  <data key="d2">chunk-abdc58b38877ec6461c6365a97abe8cd</data>
</node>
<node id="&lt;hyperedge&gt;&quot;We may communicate with you about your application and about other products and services that may be of interest to you. We may contact you by phone or text at the number(s) you have provided, or by mail, email or other electronic methods.&quot;">
  <data key="d0">hyperedge</data>
  <data key="d1">8.0</data>
  <data key="d2">chunk-abdc58b38877ec6461c6365a97abe8cd</data>
</node>
