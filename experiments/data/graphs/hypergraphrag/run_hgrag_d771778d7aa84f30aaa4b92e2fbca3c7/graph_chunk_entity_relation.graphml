<node id="&quot;TD 20-YEAR TERM LIFE INSURANCE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"INSURANCE PRODUCT"</data>
  <data key="d4">"A 20-year term life insurance policy offered by TD Insurance, with policy number 123 456 789, enclosed in the booklet."&lt;SEP&gt;"A 20-year term life insurance product offered by TD Life."&lt;SEP&gt;"A life insurance policy that provides a fixed-term coverage of 20 years, ensuring financial protection for dependents in the event of the insured's death."&lt;SEP&gt;"A life insurance policy that renews automatically every 20 years without a medical exam, providing coverage until age 80. Premiums are fixed per term and guaranteed not to increase until renewal."&lt;SEP&gt;"A life insurance policy with a 20-year term, offered by TD Life."&lt;SEP&gt;"A life insurance policy with a 20-year term, under which the Waiver of Premiums Benefit may be selected."&lt;SEP&gt;"A life insurance product offered by TD Insurance with a 20-year term, providing death benefit coverage for the policyholder."&lt;SEP&gt;"A life insurance product offered by TD with a 20-year term."&lt;SEP&gt;"A type of life insurance that provides coverage for a 20-year term with fixed premiums, renewable up to age 80, and can be converted to permanent insurance without a medical exam."&lt;SEP&gt;"The specific life insurance product offered by TD Insurance, with a 20-year term duration."&lt;SEP&gt;"The specific plan under which the policy is issued."</data>
  <data key="d2">chunk-cf1db72640089d7922b6f3c8990a770c&lt;SEP&gt;chunk-3176395bb041cd38db29d25c821dd001&lt;SEP&gt;chunk-8e620317e605d626d8ab870e46de6f7a&lt;SEP&gt;chunk-abdc58b38877ec6461c6365a97abe8cd&lt;SEP&gt;chunk-bcfa08654ec1fe76b2e144274924604f&lt;SEP&gt;chunk-11d4c3dcf75b46d67d20b99fae497d13&lt;SEP&gt;chunk-6edccc340f8afbd44c99a81b6ebfad57&lt;SEP&gt;chunk-0c5823797389d53c125d084de75665df</data>
