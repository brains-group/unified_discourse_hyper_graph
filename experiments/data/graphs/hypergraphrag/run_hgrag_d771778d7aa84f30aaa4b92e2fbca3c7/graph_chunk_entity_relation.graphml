  <data key="d0">hyperedge</data>
  <data key="d1">6.0</data>
  <data key="d2">chunk-11d4c3dcf75b46d67d20b99fae497d13</data>
</node>
<node id="&lt;hyperedge&gt;&quot;We will not waive premiums if total disability results, either directly or indirectly, from one or more of the following causes:&quot;">
  <data key="d0">hyperedge</data>
