  <data key="d0">entity</data>
  <data key="d3">"FINANCIAL METRIC"</data>
  <data key="d4">"The net cost of a policy loan is 1% annually, reflecting the difference between interest paid and interest earned."</data>
  <data key="d2">chunk-49f6114331e9af8d645ae31de47f62d6</data>
</node>
