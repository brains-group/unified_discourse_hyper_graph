  <data key="d0">entity</data>
  <data key="d3">"DURATION"</data>
  <data key="d4">"The crediting period for the Global Diversified Index Account."&lt;SEP&gt;"The crediting period for the NASDAQ-100 Index Account."&lt;SEP&gt;"The crediting period for the S&amp;P 500 Index Account."</data>
  <data key="d2">chunk-8c5042e90fe6248acf672391208bb506&lt;SEP&gt;chunk-29c4478dd9be0cdf43be914d5e56c59f</data>
