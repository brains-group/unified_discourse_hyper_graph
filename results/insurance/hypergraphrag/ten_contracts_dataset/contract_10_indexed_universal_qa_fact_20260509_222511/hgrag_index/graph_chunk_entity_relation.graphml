  <data key="d2">chunk-51042d483c612bb4904ff39555059fab</data>
</node>
<node id="&quot;POINT-TO-POINT METHOD&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CREDITING_METHOD"</data>
  <data key="d4">"A method of calculating interest credits based on the difference between the index value at the start and end of a crediting period."</data>
  <data key="d2">chunk-29c4478dd9be0cdf43be914d5e56c59f</data>
</node>
