<node id="&quot;DEATH DURING TERM ROP&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PROVISION"</data>
  <data key="d4">"A provision that provides beneficiaries with the full death benefit and a proportional premium refund based on the early surrender schedule if the insured dies during the term."</data>
  <data key="d2">chunk-76f7968940652a9b1983b6200ac06471</data>
</node>
<node id="&quot;PREFERRED PLUS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"RATING_CLASS"</data>
  <data key="d4">"A health rating indicating excellent health."&lt;SEP&gt;"A premium rating classification indicating the insured is in excellent health and qualifies for the lowest available premiums."&lt;SEP&gt;"A premium rating for individuals in excellent health."&lt;SEP&gt;"Excellent health rating."</data>
  <data key="d2">chunk-ca51dc15ca1d4c642c64ecef44f3c6a0</data>
</node>
<node id="&quot;TAXABLE GAIN&quot;">
