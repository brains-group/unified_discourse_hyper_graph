  <data key="d0">entity</data>
  <data key="d3">"SECTION"</data>
  <data key="d4">"The section of the policy that identifies the individual who owns the policy and the person whose life is insured."</data>
  <data key="d2">chunk-fde85eeed0e7ef938be9b3d18c3183ef</data>
</node>
<node id="&quot;06102&quot;">
  <data key="d0">entity</data>
  <data key="d3">"POSTAL CODE"</data>
