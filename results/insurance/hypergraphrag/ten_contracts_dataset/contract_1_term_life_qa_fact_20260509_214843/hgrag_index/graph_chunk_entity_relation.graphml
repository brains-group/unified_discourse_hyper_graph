  <data key="d4">"The insurer is not responsible for the validity of any assignment."</data>
  <data key="d2">chunk-bd95d6b8fc6079aaa04ca42829989a10</data>
</node>
<node id="&quot;LIABILITY&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"The insurer's liability is limited to a refund of premiums paid if suicide occurs within two years."</data>
  <data key="d2">chunk-bd95d6b8fc6079aaa04ca42829989a10</data>
</node>
<node id="&quot;POLICY&quot;">
  <data key="d0">entity</data>
  <data key="d3">"DOCUMENT"</data>
