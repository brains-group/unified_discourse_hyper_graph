  <data key="d2">chunk-bd95d6b8fc6079aaa04ca42829989a10</data>
</node>
<node id="&quot;LUMP SUM PAYMENT&quot;">
  <data key="d0">entity</data>
  <data key="d3">"SETTLEMENT_OPTION"</data>
  <data key="d4">"The default method of paying the death benefit in a single, immediate payment."</data>
  <data key="d2">chunk-fde85eeed0e7ef938be9b3d18c3183ef</data>
</node>
<node id="&quot;DEATH CERTIFICATE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"DOCUMENT"</data>
