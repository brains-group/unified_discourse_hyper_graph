  <data key="d2">chunk-fde85eeed0e7ef938be9b3d18c3183ef</data>
</node>
<node id="&quot;GRACE PERIOD&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"A 31-day period following the premium due date during which coverage remains active even if the premium has not been paid."&lt;SEP&gt;"The grace period is a time frame during which the policyholder can pay the premium without the policy lapsing."</data>
  <data key="d2">chunk-fde85eeed0e7ef938be9b3d18c3183ef&lt;SEP&gt;chunk-bd95d6b8fc6079aaa04ca42829989a10</data>
</node>
<node id="&quot;MISSTATEMENT OF AGE OR SEX&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"A misstatement occurs when the insured's age or sex is incorrectly reported on the application."</data>
  <data key="d2">chunk-bd95d6b8fc6079aaa04ca42829989a10</data>
</node>
<node id="&quot;MONTHLY AUTOMATIC DEDUCTION&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PAYMENT_MODE"</data>
  <data key="d4">"The method by which premiums are paid—automatically deducted from the policyholder’s account each month."</data>
  <data key="d2">chunk-fde85eeed0e7ef938be9b3d18c3183ef</data>
</node>
<node id="&quot;MARCH 22, 1985&quot;">
