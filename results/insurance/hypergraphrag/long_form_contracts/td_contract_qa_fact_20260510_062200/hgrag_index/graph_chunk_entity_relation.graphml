  <data key="d4">"TD may contact you by text."</data>
  <data key="d2">chunk-d74a69ffda2d0b7001588e51837113ef</data>
</node>
<node id="&quot;ANNUAL PAYMENT&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PAYMENT METHOD"</data>
  <data key="d4">"Premiums are paid annually, with the first due on the First Premium Due Date in the Policy Schedule."</data>
  <data key="d2">chunk-cb04334968af2cf23772b1234fa1ff3c</data>
</node>
<node id="&quot;PRIVACY AGREEMENT&quot;">
  <data key="d0">entity</data>
  <data key="d3">"DOCUMENT"</data>
  <data key="d4">"A document included with the Policy Package that describes how personal information may be collected, used, and disclosed."&lt;SEP&gt;"A legal document outlining how personal information will be handled and protected. It must be reviewed and retained."</data>
  <data key="d2">chunk-7c9b2d4d50f1eb65ffb1c24f16aaff10&lt;SEP&gt;chunk-d6297aea6185daf9585122e54b144c60</data>
</node>
<node id="&quot;PERCENTAGE ALLOCATION&quot;">
  <data key="d0">entity</data>
  <data key="d3">"FINANCIAL REQUIREMENT"</data>
  <data key="d4">"The sum of all beneficiary percentages must total 100%."</data>
  <data key="d2">chunk-dfd5028f0b43132db8da74961939d00d</data>
</node>
<node id="&quot;REINSTATEMENT EFFECTIVE DATE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"TIME PERIOD"</data>
  <data key="d4">"Reinstatement Effective Date is the specific date when the policy is restored to active status."&lt;SEP&gt;"The date when a previously lapsed policy is reinstated."&lt;SEP&gt;"The date when insurance is reinstated."&lt;SEP&gt;"The date when the reinstated policy becomes effective."</data>
  <data key="d2">chunk-cb04334968af2cf23772b1234fa1ff3c&lt;SEP&gt;chunk-9e48b2c7f5c340d231cab1e863dc3229&lt;SEP&gt;chunk-d797d61d4936328367b970f1b1a2a94b</data>
</node>
<node id="&quot;MINOR CHILD&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PERSON"</data>
  <data key="d4">"A child under the age of majority who is designated as an irrevocable beneficiary."</data>
  <data key="d2">chunk-b8865028ed52b3b23f75c2db4581d310</data>
</node>
<node id="&quot;CREDIT CARD ENDING IN 1234&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PAYMENT METHOD"</data>
  <data key="d4">"Credit Card ending in 1234 is the payment method used for premium payments."&lt;SEP&gt;"Credit Card ending in 1234 is the payment method, repeated in the policy schedule."</data>
  <data key="d2">chunk-15042c9c78a8efe744537c5c84db0f52</data>
</node>
<node id="&quot;65TH BIRTHDAY&quot;">
  <data key="d0">entity</data>
  <data key="d3">"TIME"</data>
  <data key="d4">"The age at which premium payments for the waiver of premiums benefit cease."&lt;SEP&gt;"The age limit before which disability must occur."&lt;SEP&gt;"The premiums for the waiver benefit are payable until the insured person's 65th birthday."</data>
  <data key="d2">chunk-e336bc3335eae1b8a9a02061f363f289&lt;SEP&gt;chunk-d797d61d4936328367b970f1b1a2a94b&lt;SEP&gt;chunk-6e3c19fad0ec74d4024195693875376d</data>
</node>
