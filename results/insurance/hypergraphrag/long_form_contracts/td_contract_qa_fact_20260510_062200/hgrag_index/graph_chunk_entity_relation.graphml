  <data key="d3">"PRODUCT"</data>
  <data key="d4">"A life insurance policy offered by TD Insurance with a 20-year term, guaranteed premiums, and automatic renewal options."&lt;SEP&gt;"A life insurance policy that provides coverage for 20-year terms, renewable automatically without a medical exam, until age 80."&lt;SEP&gt;"A life insurance policy with a 20-year term, offered by TD Insurance."&lt;SEP&gt;"A life insurance product for which the Waiver of Premiums Benefit may be selected."&lt;SEP&gt;"A life insurance product with a 20-year term."&lt;SEP&gt;"A type of life insurance product for which the applicant applies, with a 20-year term."&lt;SEP&gt;"A type of life insurance providing coverage for 20 years, designed to protect the financial security of the insured's loved ones in the event of death."&lt;SEP&gt;"TD 20-Year Term Life Insurance is a life insurance product offered by TD Life Insurance Company, providing coverage for 20 years with a fixed premium for the initial term."&lt;SEP&gt;"TD 20-Year Term Life Insurance is the plan name, indicating a 20-year term life insurance product."&lt;SEP&gt;"TD 20-Year Term Life insurance is described as the smart choice."&lt;SEP&gt;"TD 20-year Term Life insurance is a product that helps secure the financial future of loved ones in the event of the policyholder's death."</data>
  <data key="d2">chunk-7c9b2d4d50f1eb65ffb1c24f16aaff10&lt;SEP&gt;chunk-d797d61d4936328367b970f1b1a2a94b&lt;SEP&gt;chunk-15042c9c78a8efe744537c5c84db0f52&lt;SEP&gt;chunk-d6297aea6185daf9585122e54b144c60&lt;SEP&gt;chunk-3987d1322918db88e8961dd954bc3f19&lt;SEP&gt;chunk-e336bc3335eae1b8a9a02061f363f289&lt;SEP&gt;chunk-9664b19d2f37c02c2b9b34d8418fd48b&lt;SEP&gt;chunk-8671bd5f2e04dc9f4cc083e33b5d5daf&lt;SEP&gt;chunk-5e6240fb2796b537f797e57d0cca4a3b</data>
