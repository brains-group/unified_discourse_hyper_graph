<node id="&quot;AUTO BUSINESS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"A business involving the sale, repair, or operation of vehicles."&lt;SEP&gt;"An auto business refers to any employment or engagement involving the use or maintenance of a vehicle, which triggers an exclusion."&lt;SEP&gt;"Any business involving automobiles, such as repair, sales, or operation for profit."&lt;SEP&gt;"Auto business refers to the business activities involving selling, leasing, repairing, parking, storing, servicing, delivering, or testing vehicles."</data>
  <data key="d2">chunk-245fa605e8e023a6acdcf8c36c35930e&lt;SEP&gt;chunk-6ea57b3201f9d42edca3669635573a74&lt;SEP&gt;chunk-8918d81dfdf6055a12c8c1d621356d08&lt;SEP&gt;chunk-3bb98005a1307a094baa1b3869aeea6c</data>
