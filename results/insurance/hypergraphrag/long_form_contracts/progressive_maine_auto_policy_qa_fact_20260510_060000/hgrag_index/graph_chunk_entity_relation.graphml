<node id="&quot;PREMIUM&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"The amount paid by the insured for insurance coverage, determined by various factors including personal and vehicle data."&lt;SEP&gt;"The amount paid by the insured to maintain coverage under the policy."&lt;SEP&gt;"The amount paid by the policyholder for insurance coverage."&lt;SEP&gt;"The amount paid by the policyholder to maintain insurance coverage."&lt;SEP&gt;"The amount paid for insurance coverage."&lt;SEP&gt;"The cost of insurance that may be adjusted based on changes in information."&lt;SEP&gt;"The cost of insurance."&lt;SEP&gt;"The payment made by the policyholder to maintain coverage."&lt;SEP&gt;"The premium is a payment made by the insured to maintain coverage."&lt;SEP&gt;"The premium is the amount paid by the policyholder in return for insurance coverage."&lt;SEP&gt;"The premium is the cost for this coverage, which includes payment for damages resulting from bodily injury and property damage due to an accident."&lt;SEP&gt;"The premium is the payment required to maintain insurance coverage."&lt;SEP&gt;"The regular payment made by the policyholder to maintain insurance coverage."</data>
  <data key="d2">chunk-20da18c34f7340c40297873edec25e72&lt;SEP&gt;chunk-2e3e05ae8cb995bb756587490f5512f4&lt;SEP&gt;chunk-8a3491a1885e53367b27b22e975a6fbb&lt;SEP&gt;chunk-38c1857f7eddbd65f102ae432a80d4ea&lt;SEP&gt;chunk-9ac858e839dd324c4b80701da2b87bd7&lt;SEP&gt;chunk-708cd65887876aa076b711ced7a4979e&lt;SEP&gt;chunk-d016c8b9bbaa3c5bae4936f9d698a1c1&lt;SEP&gt;chunk-ed4d5b68d5d2c5cb43c341277461c05d&lt;SEP&gt;chunk-d2d8f56664f7ecfe69d0c03f4f89540c&lt;SEP&gt;chunk-55b66238ae6adb6999a975e6b7f7834c&lt;SEP&gt;chunk-798fdf9e8255810d437349cea720f315</data>
