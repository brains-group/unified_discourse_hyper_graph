<node id="&quot;POLICY CONTRACT&quot;">
  <data key="d0">entity</data>
  <data key="d3">"DOCUMENT"</data>
  <data key="d4">"A formal agreement that outlines the terms and conditions of an insurance policy, including all agreements between the insured and the insurer."&lt;SEP&gt;"The policy contract is part of the policy and outlines the agreement between the insurer and the insured."&lt;SEP&gt;"The policy contract is the primary legal document governing the insurance agreement."</data>
  <data key="d2">chunk-20da18c34f7340c40297873edec25e72&lt;SEP&gt;chunk-2e3e05ae8cb995bb756587490f5512f4&lt;SEP&gt;chunk-e2c04092b664c68f63780007564ef50d</data>
</node>
<node id="&quot;MECHANICAL PARTS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"OBJECT"</data>
  <data key="d4">"Functional components of a vehicle that degrade over time and require replacement, such as engines, transmissions, or brakes."&lt;SEP&gt;"Mechanical parts are components of a vehicle that are not external crash parts, wheels, paint, windshields, or other glass."&lt;SEP&gt;"Mechanical parts that are nonfunctioning or inoperative may be subject to adjustment for depreciation or betterment in repair or replacement cost."</data>
  <data key="d2">chunk-98ea72d43f9051dc6899f8d6aafcd9a5&lt;SEP&gt;chunk-245fa605e8e023a6acdcf8c36c35930e&lt;SEP&gt;chunk-33661b5c04aa1251a71c27b799dfbfc2</data>
