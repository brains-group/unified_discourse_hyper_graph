<node id="&quot;COMPENSATION&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"Compensation is the payment received by a transportation network company for providing transportation or delivery services."&lt;SEP&gt;"Compensation refers to any form of payment received for the use of a vehicle, such as in a vehicle sharing program, which may trigger exclusions."&lt;SEP&gt;"Compensation refers to payment for services, and using a vehicle for such purposes is excluded."&lt;SEP&gt;"Payment for vehicle use."&lt;SEP&gt;"Payment or benefit received in exchange for the use of a covered auto, which triggers the exclusion."&lt;SEP&gt;"Payment received for the use of a vehicle, such as in a sharing program."&lt;SEP&gt;"Payment received for vehicle use."&lt;SEP&gt;"Payment received in exchange for the use of a vehicle."</data>
  <data key="d2">chunk-245fa605e8e023a6acdcf8c36c35930e&lt;SEP&gt;chunk-d016c8b9bbaa3c5bae4936f9d698a1c1&lt;SEP&gt;chunk-9d1b4fcafc6c7d7efe5c322ad9bd33fd&lt;SEP&gt;chunk-55b66238ae6adb6999a975e6b7f7834c&lt;SEP&gt;chunk-cfb324337b8eb7e557e96d41d0a59527</data>
