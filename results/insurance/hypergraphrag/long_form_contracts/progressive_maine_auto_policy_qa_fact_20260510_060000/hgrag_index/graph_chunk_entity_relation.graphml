<node id="&quot;AUTO&quot;">
  <data key="d0">entity</data>
  <data key="d3">"OBJECT"</data>
  <data key="d4">"A motor vehicle that is covered under the policy."&lt;SEP&gt;"A motor vehicle used by a non-resident in a foreign jurisdiction."&lt;SEP&gt;"A motor vehicle."&lt;SEP&gt;"A vehicle covered under the policy."&lt;SEP&gt;"An auto is a land motor vehicle designed for use on public roads, and occupancy of it is a condition for being an 'Insured person'."&lt;SEP&gt;"An auto is a motor vehicle covered under this policy, and accidents arising from its ownership, maintenance, or use are covered."&lt;SEP&gt;"An auto is a vehicle covered under the policy."&lt;SEP&gt;"An auto is a vehicle shown on the declarations page and may be replaced by a replacement auto."&lt;SEP&gt;"An auto is defined as a land motor vehicle that is of the private passenger, pickup body, or cargo van type, designed for operation on public roads, has at least four wheels, and has a gross vehicle weight rating of 12,000 pounds or less."</data>
  <data key="d2">chunk-2e3e05ae8cb995bb756587490f5512f4&lt;SEP&gt;chunk-3bb98005a1307a094baa1b3869aeea6c&lt;SEP&gt;chunk-d016c8b9bbaa3c5bae4936f9d698a1c1&lt;SEP&gt;chunk-8918d81dfdf6055a12c8c1d621356d08&lt;SEP&gt;chunk-6ea57b3201f9d42edca3669635573a74&lt;SEP&gt;chunk-55b66238ae6adb6999a975e6b7f7834c&lt;SEP&gt;chunk-798fdf9e8255810d437349cea720f315</data>
