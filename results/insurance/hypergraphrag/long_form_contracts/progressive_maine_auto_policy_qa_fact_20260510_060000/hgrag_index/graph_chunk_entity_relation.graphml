  <data key="d0">entity</data>
  <data key="d3">"EVENT"</data>
  <data key="d4">"A lack of essential fluids is a covered emergency."</data>
  <data key="d2">chunk-9cd680372852b670779cd9ab038f278e</data>
</node>
<node id="&quot;APPLICABLE UNINSURED OR UNDERINSURED MOTORIST COVERAGES&quot;">
  <data key="d0">entity</data>
  <data key="d3">"INSURANCE PRODUCT"</data>
  <data key="d4">"Additional insurance policies that provide protection against uninsured or underinsured drivers; their limits are combined with the primary coverage."</data>
  <data key="d2">chunk-cc674f73d7a5cb327513cff560eedac9</data>
</node>
<node id="&quot;REPAIR FACILITY&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ORGANIZATION"</data>
