  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"The act of keeping a vehicle in good condition."&lt;SEP&gt;"The act of keeping a vehicle in good working condition."&lt;SEP&gt;"The upkeep or repair of a vehicle, which must be involved in the accident."</data>
  <data key="d2">chunk-8918d81dfdf6055a12c8c1d621356d08&lt;SEP&gt;chunk-d2d8f56664f7ecfe69d0c03f4f89540c</data>
</node>
