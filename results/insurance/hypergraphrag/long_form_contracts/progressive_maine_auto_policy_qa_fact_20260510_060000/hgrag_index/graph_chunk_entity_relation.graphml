  <data key="d0">entity</data>
  <data key="d3">"OBJECT"</data>
  <data key="d4">"A trailer connected to an auto, treated as part of the same vehicle for coverage purposes."&lt;SEP&gt;"An attached trailer is a vehicle that is connected to and part of a covered auto."</data>
