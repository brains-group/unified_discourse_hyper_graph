  <data key="d0">entity</data>
  <data key="d3">"OBJECT"</data>
  <data key="d4">"A car, truck, or other motorized transport."&lt;SEP&gt;"A motorized vehicle covered under the insurance policy."&lt;SEP&gt;"A vehicle being used to carry persons or property for compensation or a fee is excluded from coverage."&lt;SEP&gt;"A vehicle is any motorized transport owned by the policyholder, a relative, or a rated resident, or furnished for regular use, and may be involved in incidents leading to injury or exclusion from coverage."&lt;SEP&gt;"A vehicle is any motorized transport, and its use for certain purposes is excluded."&lt;SEP&gt;"A vehicle is subject to exclusion for diminution of value."&lt;SEP&gt;"A vehicle is subject to exclusion if damage results from wear and tear, freezing, mechanical/electrical/electronic breakdown, or road damage to tires."&lt;SEP&gt;"A vehicle is subject to exclusion if damaged by a criminal act or omission by the insured, a relative, a rated resident, or the owner of a non-owned auto."&lt;SEP&gt;"A vehicle is subject to exclusion if damaged by war, civil war, warlike action, insurrection, rebellion, revolution, or usurped power."&lt;SEP&gt;"A vehicle is subject to exclusion if the insured, a relative, or a rated resident engaged in illegal activities."&lt;SEP&gt;"A vehicle is used in ride-sharing activity to transport persons or property."&lt;SEP&gt;"A vehicle that is stolen is not subject to the exclusion for wear and tear, freezing, breakdown, or road damage."&lt;SEP&gt;"A vehicle used by the insured, a relative, or a rated resident, which is not a covered auto and was used without permission of the owner or lawful possessor."&lt;SEP&gt;"Any motor vehicle not classified as a covered auto."</data>
  <data key="d2">chunk-20da18c34f7340c40297873edec25e72&lt;SEP&gt;chunk-245fa605e8e023a6acdcf8c36c35930e&lt;SEP&gt;chunk-8918d81dfdf6055a12c8c1d621356d08&lt;SEP&gt;chunk-d016c8b9bbaa3c5bae4936f9d698a1c1&lt;SEP&gt;chunk-9fee7a00b84094770f04dcfe86a29e3a&lt;SEP&gt;chunk-9d1b4fcafc6c7d7efe5c322ad9bd33fd&lt;SEP&gt;chunk-ba971e62cee92a6aaf201ec7e51cf087&lt;SEP&gt;chunk-55b66238ae6adb6999a975e6b7f7834c&lt;SEP&gt;chunk-cfb324337b8eb7e557e96d41d0a59527</data>
</node>
