<node id="&quot;REBELLION&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"Rebellion against governmental authority is excluded from coverage, as it may result in injuries or damages not covered."&lt;SEP&gt;"Rebellion causes vehicle damage and is excluded."</data>
  <data key="d2">chunk-9d1b4fcafc6c7d7efe5c322ad9bd33fd&lt;SEP&gt;chunk-ba971e62cee92a6aaf201ec7e51cf087</data>
