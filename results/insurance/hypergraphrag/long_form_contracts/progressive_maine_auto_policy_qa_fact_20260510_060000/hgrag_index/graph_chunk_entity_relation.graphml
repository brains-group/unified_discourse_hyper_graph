<node id="&quot;POLICY&quot;">
  <data key="d0">entity</data>
  <data key="d3">"DOCUMENT"</data>
  <data key="d4">"A document that governs insurance coverage and related procedures."&lt;SEP&gt;"A formal agreement between the insurer and policyholder outlining coverage terms and conditions."&lt;SEP&gt;"A formal agreement between the insurer and the insured outlining terms and conditions of coverage."&lt;SEP&gt;"The full insurance contract that outlines coverage, exclusions, and limits."&lt;SEP&gt;"The full insurance contract."&lt;SEP&gt;"The insurance policy is a legal document that outlines the terms, conditions, limits, and exclusions of coverage for the insured."&lt;SEP&gt;"The policy contains definitions that apply throughout its duration."&lt;SEP&gt;"The policy defines the scope of coverage and recovery obligations."&lt;SEP&gt;"The policy is a formal agreement that can be cancelled by the insurer during the policy period."&lt;SEP&gt;"The policy is a legal document that outlines the terms, conditions, and limitations of insurance coverage."&lt;SEP&gt;"The policy may be canceled or changed by any named insured."</data>
  <data key="d2">chunk-2e3e05ae8cb995bb756587490f5512f4&lt;SEP&gt;chunk-8a3491a1885e53367b27b22e975a6fbb&lt;SEP&gt;chunk-69d3b921f75f85252f4c9cdeaa3141bb&lt;SEP&gt;chunk-38c1857f7eddbd65f102ae432a80d4ea&lt;SEP&gt;chunk-d2d8f56664f7ecfe69d0c03f4f89540c&lt;SEP&gt;chunk-9d1b4fcafc6c7d7efe5c322ad9bd33fd&lt;SEP&gt;chunk-f25ed079d4b7f6c7141fd78422f7f726</data>
</node>
