<node id="&quot;REIMBURSEMENT&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"Reimbursement of the deductible is reduced by a proportionate share of collection expenses and attorney fees."&lt;SEP&gt;"Reimbursement of the deductible is reduced proportionally if recovery is less than the total of payment and deductible."&lt;SEP&gt;"The insured must reimburse the insurer to the extent of payment made."&lt;SEP&gt;"The return of funds to the policyholder for out-of-pocket expenses."</data>
  <data key="d2">chunk-8a3491a1885e53367b27b22e975a6fbb&lt;SEP&gt;chunk-69d3b921f75f85252f4c9cdeaa3141bb&lt;SEP&gt;chunk-f67c7ff74642b092b6581278092146d7</data>
