</node>
<node id="&quot;MISREPRESENTATION&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"Deliberately providing false information."&lt;SEP&gt;"False or misleading statements made during the application or claim process."&lt;SEP&gt;"False or misleading statements made during the application or claims process."&lt;SEP&gt;"False or misleading statements."&lt;SEP&gt;"Misrepresentation is a false statement that nullifies lienholder protection."&lt;SEP&gt;"Misrepresentation refers to false or misleading statements made by the policyholder or someone seeking coverage, which can lead to denial of coverage."</data>
  <data key="d2">chunk-2e3e05ae8cb995bb756587490f5512f4&lt;SEP&gt;chunk-8a3491a1885e53367b27b22e975a6fbb&lt;SEP&gt;chunk-38c1857f7eddbd65f102ae432a80d4ea&lt;SEP&gt;chunk-98ea72d43f9051dc6899f8d6aafcd9a5&lt;SEP&gt;chunk-708cd65887876aa076b711ced7a4979e</data>
