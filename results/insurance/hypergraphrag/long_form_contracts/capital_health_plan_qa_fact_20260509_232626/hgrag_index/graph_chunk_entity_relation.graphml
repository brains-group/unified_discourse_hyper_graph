<node id="&quot;PARTICIPANTS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PERSON"</data>
  <data key="d4">"Individuals enrolled in the Plan who may submit inquiries to the Department."&lt;SEP&gt;"Individuals enrolled in the health plan who are entitled to benefits."&lt;SEP&gt;"Individuals impacted by a major provider's network status change, who must be notified in advance."&lt;SEP&gt;"Individuals who receive ID Cards, including those newly enrolled or affected by changes."&lt;SEP&gt;"Individuals who will receive ID cards and education materials."&lt;SEP&gt;"Participants are individuals enrolled in or eligible for the Plan."&lt;SEP&gt;"Participants are individuals or groups who currently receive benefits under the contract and may be offered new services or programs."&lt;SEP&gt;"Participants are individuals using Plan services and are the subject of the satisfaction survey."&lt;SEP&gt;"Participants are individuals who are currently enrolled or seeking enrollment in the Plan and receive customer service support from the Customer Service Unit."&lt;SEP&gt;"Participants are individuals who have access to and can use the toll-free telephone number for communication with the Awarded Respondent."&lt;SEP&gt;"Participants are individuals who must receive written notice from the Awarded Respondent if a provider payment remains unpaid."&lt;SEP&gt;"Participants are individuals who will receive ID Cards from the Awarded Respondent and are the intended recipients of the mailing."&lt;SEP&gt;"Participants are the individuals who use the toll-free number to access customer service."</data>
  <data key="d2">chunk-b57b1f6f75687090fceb29727cfad251&lt;SEP&gt;chunk-dc984120e1f1f604e806000ba1bb8141&lt;SEP&gt;chunk-1a21de729aeac2ac5411293b5eb7a85b&lt;SEP&gt;chunk-a15086157f2c790665924983ad25ad5f&lt;SEP&gt;chunk-7afb47b665f9a355360d8f19b072515d&lt;SEP&gt;chunk-902137132fe9e53d1a269692b4827557&lt;SEP&gt;chunk-2ac2c9a651e12d0bbc80acf2a9565c92&lt;SEP&gt;chunk-ced7b0d6c3e25b1f766368ff30d9f7db&lt;SEP&gt;chunk-634b420b1dffb2db682f1098aa431f4e&lt;SEP&gt;chunk-c9aaa428a9cedb15e5c65db44f369179&lt;SEP&gt;chunk-be8d8979403f6066066c55d416f7a095&lt;SEP&gt;chunk-c29476b54ecf1664862eece0459c63e6</data>
</node>
