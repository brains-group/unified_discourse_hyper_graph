<node id="&quot;YES&quot;">
  <data key="d0">entity</data>
  <data key="d3">"RESPONSE"</data>
  <data key="d4">"A confirmation that all listed wellness programs are included in the HMO plan for each year from 2024 to 2029."&lt;SEP&gt;"A confirmation that all wellness programs are included in the HMO plan for each year from 2024 to 2029."&lt;SEP&gt;"A positive response indicating agreement or availability of a service or feature."&lt;SEP&gt;"Indicates that HMO service access is confirmed in Franklin County."&lt;SEP&gt;"The program component is provided as a standard part of the program in multiple conditions."&lt;SEP&gt;"The program component is provided as a standard part of the program."&lt;SEP&gt;"The status for Franklin in Region 2 is 'Yes', indicating eligibility is available."&lt;SEP&gt;"The status for Gadsden in Region 2 is 'Yes', indicating eligibility is available."&lt;SEP&gt;"The status for Jefferson in Region 2 is 'Yes', indicating eligibility is available."&lt;SEP&gt;"The status for Leon in Region 2 is 'Yes', indicating eligibility is available."&lt;SEP&gt;"The status for Liberty in Region 2 is 'Yes', indicating eligibility is available."&lt;SEP&gt;"The status for Madison in Region 2 is 'Yes', indicating eligibility is available."&lt;SEP&gt;"The status for Taylor in Region 2 is 'Yes', indicating eligibility is available."&lt;SEP&gt;"The status for Wakulla in Region 2 is 'Yes', indicating eligibility is available."&lt;SEP&gt;"Yes is a response indicating availability or support for a health service or feature across the six instances."</data>
  <data key="d2">chunk-4a0d21d26b536ddb1d9857e75140678f&lt;SEP&gt;chunk-9d8bc7fada8f87797f63efcdf326ef70&lt;SEP&gt;chunk-0fdce96abe4b716dd4076eb221495668&lt;SEP&gt;chunk-ad1bb006a6b3b5dd26c6197fe6c2b684&lt;SEP&gt;chunk-18ed6bd678bd05e4b28c9ca879edceda&lt;SEP&gt;chunk-5cd8c10bc4bb6434e32a2b884812a482</data>
</node>
