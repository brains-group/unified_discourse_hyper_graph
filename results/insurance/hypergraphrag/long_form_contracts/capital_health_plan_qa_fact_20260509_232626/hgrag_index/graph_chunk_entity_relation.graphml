<node id="&quot;EVENT OF DEFAULT&quot;">
  <data key="d0">entity</data>
  <data key="d3">"EVENT"</data>
  <data key="d4">"An Event of Default is a condition or failure by the Contractor that, if not cured within 10 calendar days after notice, triggers default status."&lt;SEP&gt;"An Event of Default is a failure by the Department to meet contractual obligations."&lt;SEP&gt;"An Event of Default is a formal declaration by the Department when performance fails for three consecutive quarters, allowing for alternative remedies."&lt;SEP&gt;"An Event of Default occurs when the Department fails to meet its contractual obligations, triggering remedies for the Contractor."&lt;SEP&gt;"Failure to meet obligations under this subsection constitutes an Event of Default."</data>
  <data key="d2">chunk-79a76389ae9d41ad98c308997796bb27&lt;SEP&gt;chunk-6e76ed74a8f332bb4b0ce48da988e36a&lt;SEP&gt;chunk-eaa3b36fea58d72059cd585dada27264&lt;SEP&gt;chunk-f27e3efb4e453bfd444a2596a8c9623f&lt;SEP&gt;chunk-80197926c45627b0efe3aa47310d15c0</data>
