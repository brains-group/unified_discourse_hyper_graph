  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"Activities such as repairing, servicing, testing, washing, parking, storing, or selling of autos."&lt;SEP&gt;"Auto business operations include repairing, servicing, testing, washing, parking, storing, or selling of autos."</data>
  <data key="d2">chunk-ccb8c813f593e1d6b773fb60656c296b&lt;SEP&gt;chunk-7b55b5dbebd0735cd54f0def3352978c</data>
