<node id="&quot;DISEASE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONDITION"</data>
  <data key="d4">"A pathological condition affecting the body that may be covered under bodily injury."&lt;SEP&gt;"A pathological condition that may result in bodily injury."&lt;SEP&gt;"A pathological condition, excluded from coverage."&lt;SEP&gt;"Disease caused by an auto accident is a condition that may lead to benefit payment."&lt;SEP&gt;"Disease is a medical condition caused by an auto accident and may be covered."&lt;SEP&gt;"Disease is a medical condition that may lead to disability."</data>
  <data key="d2">chunk-442e0db5ed8682bcab7a54824da0d7b5&lt;SEP&gt;chunk-52f5f0f71f1ab344627208359e420446&lt;SEP&gt;chunk-1a3c5316326203ee0a115e648929c62e&lt;SEP&gt;chunk-810b812ea27a9a4ae98ffeee6a14930d&lt;SEP&gt;chunk-eb067276caaf4fa58c030146cde3e6e7&lt;SEP&gt;chunk-ccb8c813f593e1d6b773fb60656c296b</data>
</node>
<node id="&quot;SERVICED OR REPAIRED&quot;">
  <data key="d0">entity</data>
