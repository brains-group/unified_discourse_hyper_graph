  <data key="d0">entity</data>
  <data key="d3">"PROCESS"</data>
  <data key="d4">"Notification to Allstate is required within 30 days of certain events, such as a hit-and-run accident."&lt;SEP&gt;"Notification to Allstate within 60 days of acquiring a new auto is required to maintain coverage."&lt;SEP&gt;"The policyholder must notify Allstate within 60 days of acquiring a new motor vehicle."</data>
  <data key="d2">chunk-9464bb7af811d8f15562644a4b28627a&lt;SEP&gt;chunk-82005be4122ff546dea4915156b29767</data>
