  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"Allstate is responsible for paying valid claims as defined by the policy, subject to limits and conditions."</data>
  <data key="d2">chunk-cbd2304da521f1c8202f189b37a4ffb4</data>
</node>
