  <data key="d2">chunk-12ffe8b6b2ba410a0c8e955ca34e8cfb</data>
</node>
<node id="&quot;COMMERCIAL AUTO&quot;">
  <data key="d0">entity</data>
  <data key="d3">"OBJECT"</data>
  <data key="d4">"A commercial auto is a vehicle used for business purposes, and duties related to its use are excluded from coverage."&lt;SEP&gt;"A commercial auto is a vehicle used for business purposes, and its use is excluded from coverage."</data>
  <data key="d2">chunk-de3dee890ed2c9f37d79ceb62462bb87&lt;SEP&gt;chunk-52f5f0f71f1ab344627208359e420446</data>
