  <data key="d2">chunk-82005be4122ff546dea4915156b29767</data>
</node>
<node id="&quot;LIKE KIND AND QUALITY&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"A standard for replacement property that matches the original in type and quality."</data>
  <data key="d2">chunk-12ffe8b6b2ba410a0c8e955ca34e8cfb</data>
</node>
<node id="&quot;PERSON&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PERSON"</data>
  <data key="d4">"A person is an individual whose death during an occupation is excluded from coverage."&lt;SEP&gt;"A person legally entitled to recover compensation due to bodily injury sustained by the policyholder, a relative in the household, or an occupant of an insured auto with permission."&lt;SEP&gt;"A person who receives payment under the insurance coverage."&lt;SEP&gt;"Any person who is in, on, getting into, or getting out of an insured auto with the policyholder's permission is considered an insured person."</data>
  <data key="d2">chunk-9464bb7af811d8f15562644a4b28627a&lt;SEP&gt;chunk-73e94c444615403bb65cb8316d74e2ee&lt;SEP&gt;chunk-52f5f0f71f1ab344627208359e420446</data>
</node>
