  <data key="d0">entity</data>
  <data key="d3">"POLICY"</data>
  <data key="d4">"A coverage type that applies only when comprehensive insurance is in effect, providing protection for permanently installed sound systems and related apparatus in an auto."&lt;SEP&gt;"Coverage ZA is a policy coverage that, if purchased, exempts the exclusion."&lt;SEP&gt;"Coverage ZA is a section of the policy, though no details are provided."</data>
  <data key="d2">chunk-9177db9bf28d1b94e41d2945af46c2ed&lt;SEP&gt;chunk-8be2695f13a2055df9eb3b1f448e01ac&lt;SEP&gt;chunk-7b55b5dbebd0735cd54f0def3352978c</data>
