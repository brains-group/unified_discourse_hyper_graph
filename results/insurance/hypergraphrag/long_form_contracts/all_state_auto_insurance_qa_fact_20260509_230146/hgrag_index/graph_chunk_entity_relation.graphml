<node id="&quot;DEDUCTIBLE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"A separate deductible applies to both the auto and the camper unit when unmounted."&lt;SEP&gt;"An amount subtracted from the actual cash value, as specified in the Policy Declarations."&lt;SEP&gt;"An amount the insured must pay for each separate auto, including an attached trailer."&lt;SEP&gt;"Any coverage with a deductible will always apply, regardless of other coverage."&lt;SEP&gt;"No deductible applies to losses exceeding $100."</data>
