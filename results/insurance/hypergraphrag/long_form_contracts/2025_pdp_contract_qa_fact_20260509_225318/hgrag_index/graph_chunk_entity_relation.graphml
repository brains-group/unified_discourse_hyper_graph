<node id="&quot;GOVERNMENT&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ORGANIZATION"</data>
  <data key="d4">"The Government refers to federal and state agencies that oversee compliance and receive notifications regarding integrity items."&lt;SEP&gt;"The U.S. federal government, which receives a license to use formulary data for Part D program administration."&lt;SEP&gt;"The federal government, including CMS, responsible for overseeing Medicare payments."</data>
  <data key="d2">chunk-647561dd6831e3ae72c2d43faf5b0b9f&lt;SEP&gt;chunk-089a3e7f57f00ea7d36a53726e96e60c&lt;SEP&gt;chunk-b14ea02aabc3c1d74ff07de937978aa9</data>
</node>
<node id="&quot;SUBCONTRACTORS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ORGANIZATION"</data>
  <data key="d4">"Subcontractors are entities working on behalf of the PDP Sponsor, excluding contracted network providers, and are subject to the same scrutiny regarding investigations and legal actions."&lt;SEP&gt;"Third-party entities hired by the PDP Sponsor to perform specific services, excluding contracted network providers, who must be disclosed if involved in integrity issues."</data>
  <data key="d2">chunk-089a3e7f57f00ea7d36a53726e96e60c&lt;SEP&gt;chunk-d33402aba37c5664514afa00a872b8ae</data>
</node>
<node id="&quot;PART D SUMMARY PLAN RATING SCORE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"METRIC"</data>
  <data key="d4">"A performance rating system used to evaluate Medicare Part D plans based on quality, customer service, and drug management."</data>
  <data key="d2">chunk-647561dd6831e3ae72c2d43faf5b0b9f</data>
</node>
<node id="&quot;RECONCILIATION OF PART D PAYMENTS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PROCESS"</data>
  <data key="d4">"The process of verifying and adjusting payments made to the PDP Sponsor to ensure accuracy and compliance."</data>
  <data key="d2">chunk-89bdab9933b704535281ee7396b3c0c8</data>
</node>
<node id="&quot;WWW.MEDICARE.GOV&quot;">
  <data key="d0">entity</data>
  <data key="d3">"WEBSITE"</data>
  <data key="d4">"The official website of Medicare, where formulary information may be publicly distributed."</data>
  <data key="d2">chunk-b14ea02aabc3c1d74ff07de937978aa9</data>
</node>
<node id="&quot;KEY MANAGEMENT OR EXECUTIVE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PERSON"</data>
  <data key="d4">"Senior leaders or executives within the PDP Sponsor organization who may be involved in or subject to integrity-related matters."</data>
  <data key="d2">chunk-d33402aba37c5664514afa00a872b8ae</data>
</node>
<node id="&quot;3 STARS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"RATING"</data>
  <data key="d4">"A minimum performance threshold required for PDP Sponsors under federal regulation."</data>
  <data key="d2">chunk-647561dd6831e3ae72c2d43faf5b0b9f</data>
</node>
<node id="&quot;42 CFR § 423.505(O)(1)&quot;">
  <data key="d0">entity</data>
  <data key="d3">"REGULATION"</data>
  <data key="d4">"A regulation requiring the submission and public release of reconciled Part D payment data."</data>
  <data key="d2">chunk-89bdab9933b704535281ee7396b3c0c8</data>
</node>
<node id="&quot;PUBLIC DISTRIBUTION&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"The act of making formulary information available to the public, permitted under the license."</data>
  <data key="d2">chunk-b14ea02aabc3c1d74ff07de937978aa9</data>
</node>
<node id="&quot;BEST KNOWLEDGE, INFORMATION, AND BELIEF&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"A standard of disclosure requiring PDP Sponsors to report integrity items based on their current understanding, even if not fully confirmed."</data>
  <data key="d2">chunk-d33402aba37c5664514afa00a872b8ae</data>
</node>
<node id="&quot;42 CFR § 423.505(B)(26)&quot;">
  <data key="d0">entity</data>
  <data key="d3">"REGULATION"</data>
  <data key="d4">"Federal regulation mandating a minimum 3-star rating for Part D plans."</data>
  <data key="d2">chunk-647561dd6831e3ae72c2d43faf5b0b9f</data>
</node>
<node id="&quot;PART D MEDICAL LOSS RATIO DATA&quot;">
  <data key="d0">entity</data>
  <data key="d3">"INFORMATION"</data>
  <data key="d4">"Data measuring the percentage of premium dollars spent on medical services versus administrative costs, required to be disclosed annually."</data>
  <data key="d2">chunk-89bdab9933b704535281ee7396b3c0c8</data>
</node>
<node id="&quot;DISPLAY&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"The act of presenting formulary information in a visible format, permitted under the license."</data>
  <data key="d2">chunk-b14ea02aabc3c1d74ff07de937978aa9</data>
</node>
<node id="&quot;ROLLEES&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PERSON"</data>
  <data key="d4">"Rollees are individuals who receive notices or outbound telephone calls regarding prescription drug coverage options."</data>
  <data key="d2">chunk-a8d49cc5f599bfb3f6f139071bb0cfac</data>
</node>
<node id="&quot;ESSENTIAL OPERATIONS TEST&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ASSESSMENT"</data>
  <data key="d4">"A mandatory evaluation for new PDP Sponsors to ensure operational readiness before offering Part D benefits."</data>
  <data key="d2">chunk-647561dd6831e3ae72c2d43faf5b0b9f</data>
</node>
<node id="&quot;42 CFR § 423.2490&quot;">
  <data key="d0">entity</data>
  <data key="d3">"REGULATION"</data>
  <data key="d4">"A federal regulation that defines the requirements for reporting and disclosing Part D Medical Loss Ratio data."</data>
  <data key="d2">chunk-89bdab9933b704535281ee7396b3c0c8</data>
</node>
<node id="&quot;PUBLISHING&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"The act of releasing formulary information to a wider audience, permitted under the license."</data>
  <data key="d2">chunk-b14ea02aabc3c1d74ff07de937978aa9</data>
</node>
<node id="&quot;NOTICE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"DOCUMENT"</data>
  <data key="d4">"A notice is a formal communication that must be approved by CMS before use."</data>
  <data key="d2">chunk-a8d49cc5f599bfb3f6f139071bb0cfac</data>
</node>
<node id="&quot;NEW SPONSORS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ORGANIZATION"</data>
  <data key="d4">"PDP Sponsors that have not previously contracted with CMS for Part D benefits."</data>
  <data key="d2">chunk-647561dd6831e3ae72c2d43faf5b0b9f</data>
</node>
<node id="&quot;42 CFR § 423.128&quot;">
  <data key="d0">entity</data>
  <data key="d3">"REGULATION"</data>
  <data key="d4">"A regulation specifying the methods and formats for disclosing information to beneficiaries by the PDP Sponsor."</data>
  <data key="d2">chunk-89bdab9933b704535281ee7396b3c0c8</data>
</node>
<node id="&quot;RECONFIGURATION&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"The act of modifying or restructuring formulary data for different uses, permitted under the license."</data>
  <data key="d2">chunk-b14ea02aabc3c1d74ff07de937978aa9</data>
</node>
<node id="&quot;PRESCRIPTION DRUG COVERAGE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"Qualified prescription drug coverage is available within the PDP region."</data>
  <data key="d2">chunk-a8d49cc5f599bfb3f6f139071bb0cfac</data>
</node>
<node id="&quot;PART D CONTRACT&quot;">
  <data key="d0">entity</data>
  <data key="d3">"AGREEMENT"</data>
  <data key="d4">"A formal agreement between a PDP Sponsor and CMS to offer Medicare Part D prescription drug benefits."</data>
  <data key="d2">chunk-647561dd6831e3ae72c2d43faf5b0b9f</data>
</node>
<node id="&quot;42 CFR PART 423 SUBPART V&quot;">
  <data key="d0">entity</data>
  <data key="d3">"REGULATION"</data>
  <data key="d4">"A section of federal regulations that governs the disclosure of information to beneficiaries, including notices and communications."</data>
  <data key="d2">chunk-89bdab9933b704535281ee7396b3c0c8</data>
</node>
<node id="&quot;ELECTRONIC DISTRIBUTION&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"The transmission of formulary data via digital means, permitted under the license."</data>
  <data key="d2">chunk-b14ea02aabc3c1d74ff07de937978aa9</data>
</node>
