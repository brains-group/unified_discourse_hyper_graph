<node id="&quot;FISCALLY SOUND OPERATION&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"A financial state in which a PDP Sponsor maintains sufficient financial health to operate reliably, defined by positive net worth."</data>
  <data key="d2">chunk-a1ba6b4dc9d71dff813e0972c4e6c371</data>
</node>
<node id="&quot;ENROLLMENTS EFFECTIVE&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"The process of making enrollments officially active."</data>
  <data key="d2">chunk-98acde792b4efcfd60a0e94224e24870</data>
</node>
<node id="&quot;CERTIFICATIONS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"DOCUMENT"</data>
  <data key="d4">"Formal statements provided by the PDP Sponsor to verify compliance with regulatory requirements."</data>
  <data key="d2">chunk-089a3e7f57f00ea7d36a53726e96e60c</data>
</node>
<node id="&quot;FALSE CLAIMS ACT&quot;">
  <data key="d0">entity</data>
  <data key="d3">"LEGAL STATUTE"</data>
  <data key="d4">"A federal law (31 U.S.C. §§ 3729 et seq.) that prohibits submitting false claims for payment to the government, including in healthcare."</data>
  <data key="d2">chunk-a77fb65c6800edbf628ea7f71f893ea5</data>
</node>
<node id="&quot;POSITIVE NET WORTH&quot;">
  <data key="d0">entity</data>
  <data key="d3">"CONCEPT"</data>
  <data key="d4">"A financial condition where total assets exceed total liabilities, required for PDP Sponsors to maintain compliance."</data>
  <data key="d2">chunk-a1ba6b4dc9d71dff813e0972c4e6c371</data>
</node>
<node id="&quot;VOLUNTARY DISENROLLMENTS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"The process of allowing beneficiaries to voluntarily leave a Medicare Part D plan."</data>
  <data key="d2">chunk-98acde792b4efcfd60a0e94224e24870</data>
</node>
<node id="&quot;FEES ESTABLISHED BY CMS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"FINANCIAL TRANSACTION"</data>
  <data key="d4">"Costs set by CMS that the PDP Sponsor must pay for enrollment-related activities."</data>
  <data key="d2">chunk-089a3e7f57f00ea7d36a53726e96e60c</data>
</node>
<node id="&quot;ANTI-KICKBACK PROVISION&quot;">
  <data key="d0">entity</data>
  <data key="d3">"LEGAL PROVISION"</data>
  <data key="d4">"Section 1128B of the Social Security Act, which prohibits offering or receiving kickbacks in connection with federal healthcare programs."</data>
  <data key="d2">chunk-a77fb65c6800edbf628ea7f71f893ea5</data>
</node>
<node id="&quot;ANTI-DISCRIMINATION LAWS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"LAW"</data>
  <data key="d4">"Laws that prohibit discrimination based on race, color, or national origin, which PDP Sponsors must comply with."</data>
  <data key="d2">chunk-a1ba6b4dc9d71dff813e0972c4e6c371</data>
</node>
<node id="&quot;INVOLUNTARY DISENROLLMENTS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"ACTION"</data>
  <data key="d4">"The process of removing beneficiaries from a plan without their consent, which must be limited."</data>
  <data key="d2">chunk-98acde792b4efcfd60a0e94224e24870</data>
</node>
<node id="&quot;COST SHARING OF ENROLLMENT RELATED COSTS&quot;">
  <data key="d0">entity</data>
  <data key="d3">"PROCESS"</data>
  <data key="d4">"The distribution of expenses associated with enrolling beneficiaries in the PDP Sponsor’s plan."</data>
  <data key="d2">chunk-089a3e7f57f00ea7d36a53726e96e60c</data>
</node>
<node id="&quot;HIPAA&quot;">
  <data key="d0">entity</data>
  <data key="d3">"LEGAL STATUTE"</data>
  <data key="d4">"The Health Insurance Portability and Accountability Act, which establishes rules for protecting health information, including privacy and security standards."</data>
  <data key="d2">chunk-a77fb65c6800edbf628ea7f71f893ea5</data>
</node>
<node id="&quot;CIVIL RIGHTS ACT OF 1964&quot;">
  <data key="d0">entity</data>
  <data key="d3">"LAW"</data>
  <data key="d4">"A landmark federal law that prohibits discrimination in various areas, including healthcare, and includes Title VI."</data>
  <data key="d2">chunk-a1ba6b4dc9d71dff813e0972c4e6c371</data>
</node>
<node id="&quot;42 CFR PART 423 SUBPART B&quot;">
  <data key="d0">entity</data>
  <data key="d3">"REGULATION"</data>
  <data key="d4">"A section of 42 CFR Part 423 that outlines enrollment rules for Medicare Part D."</data>
  <data key="d2">chunk-98acde792b4efcfd60a0e94224e24870</data>
</node>
